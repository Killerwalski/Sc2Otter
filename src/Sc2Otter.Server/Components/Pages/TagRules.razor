@page "/tags"
@rendermode InteractiveServer

@using Sc2Otter.Core.Models

<div class="page-header">
    <h2>Tag Dictionary & Rules</h2>
    <p style="color: var(--text-muted);">This dictionary defines the exact conditions under which the Local Client's automated replay analyzer will assign tags to players.</p>
</div>

<div class="card tag-rules-card" style="margin-top: 24px; padding: 32px;">
    
    @foreach (var categoryGroup in TagDictionary.AllTags.GroupBy(t => t.Category))
    {
        var color = GetCategoryColor(categoryGroup.Key);
        <h3 style="color: @color; margin-top: @(categoryGroup.Key == "Macro & Economy" ? "0" : "40px"); margin-bottom: 24px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">@categoryGroup.Key</h3>
        <div class="rules-grid">
            @foreach (var tag in categoryGroup)
            {
                @RuleRow(tag.Name, tag.Description)
            }
        </div>
    }
</div>

<style>
    .rules-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 12px;
    }
    .rule-row {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 12px;
        background-color: var(--surface-0);
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }
    .rule-tag {
        flex: 0 0 160px;
    }
    .rule-tag-badge {
        display: inline-block;
        padding: 2px 10px;
        background-color: var(--surface-1);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        font-weight: 600;
        font-size: 12px;
        color: var(--text-primary);
    }
    .rule-desc {
        flex: 1;
        color: var(--text-muted);
        line-height: 1.4;
        font-size: 13px;
    }
</style>

@code {
    private RenderFragment RuleRow(string Tag, string Description) => __builder =>
    {
        <div class="rule-row">
            <div class="rule-tag">
                <span class="rule-tag-badge">@Tag</span>
            </div>
            <div class="rule-desc">
                @Description
            </div>
        </div>
    };

    private string GetCategoryColor(string category)
    {
        return category switch
        {
            "Macro & Economy" => "var(--accent-primary)",
            "Cheese & Aggression" => "var(--accent-secondary)",
            "Unit Composition & Tech" => "#64b5f6",
            "Mass Unit" => "#ba68c8",
            _ => "var(--text-primary)"
        };
    }
}
