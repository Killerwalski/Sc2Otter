@page "/settings"
@rendermode InteractiveServer
@using Sc2Otter.Server.Services
@using Sc2Otter.Core.Interfaces
@using Sc2Otter.Server.Hubs
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@inject SettingsService SettingsService
@inject ICurrentUserService CurrentUserService
@inject IHubContext<ScoutHub> HubContext
@inject IServiceScopeFactory ScopeFactory
@inject Sc2Otter.Data.ScoutDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Settings> Logger
@using Microsoft.EntityFrameworkCore
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="page-header">
    <h1>System Configuration</h1>
    <p>Manage your LocalOtter connection and Database</p>
</div>

<div class="card">
    <div class="settings-section">
        <h3>LocalOtter Integration</h3>
        <p class="setting-description" style="margin-bottom: 15px; color: var(--accent-warning);">
            Note: Settings like your SC2 Username, Replay Directory, and Global Hotkeys are configured directly in your LocalOtter's <code>user_settings.json</code> file, not here.
        </p>
        <div class="setting-row">
            <div>
                <div class="setting-label">LocalOtter Sync Key</div>
                <div class="setting-description">
                    Your LocalOtter needs this key to send match data to your account securely. 
                    Open <code>%appdata%\Sc2Otter\user_settings.json</code> on your computer and paste this key into the <code>"SyncKey"</code> field.
                </div>
            </div>
            <div>
                @if (string.IsNullOrEmpty(SyncKey))
                {
                    <span style="color: var(--text-muted);">Loading...</span>
                }
                else
                {
                    <div style="display: flex; gap: 8px;">
                        <input type="@(ShowSyncKey ? "text" : "password")" class="form-control" style="width: 320px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" value="@SyncKey" readonly />
                        <button class="btn btn-secondary" @onclick="() => ShowSyncKey = !ShowSyncKey">
                            @(ShowSyncKey ? "Hide" : "Reveal")
                        </button>
                        <button class="btn btn-outline-primary" @onclick="GenerateSyncKey">Generate New Key</button>
                    </div>
                }
            </div>
        </div>
        <div class="setting-row" style="margin-top: 15px;">
            <div>
                <div class="setting-label">Bulk Scan Replays</div>
                <div class="setting-description">If you have old replays that you want to upload to your new cloud database, you can trigger a bulk import. This will instruct your running LocalOtter to scan all old .SC2Replay files and process them sequentially in the background.</div>
                <div class="setting-description" style="color: var(--accent-warning); font-size: 13px; margin-top: 4px;">
                    <em>Note: To prevent clutter, replays shorter than 3 minutes are automatically skipped and will not be parsed.</em>
                </div>
                @if (LastScanTime.HasValue)
                {
                    <div class="setting-description" style="color: var(--accent-success); margin-top: 8px;">
                        Last bulk scan completed at: <LocalTime UtcTime="LastScanTime.Value" IncludeYear="true" />
                    </div>
                }
            </div>
            <div style="display: flex; align-items: center; gap: 12px;">
                <button class="btn btn-warning" style="padding: 6px 12px;" @onclick="TriggerBulkImport" disabled="@_isImporting">
                    @if (_isImporting)
                    {
                        if (_importTotal > 0)
                        {
                            <span>Importing... @(_importCurrent) / @(_importTotal)</span>
                        }
                        else
                        {
                            <span>Importing in background...</span>
                        }
                    }
                    else
                    {
                        <span>Trigger Bulk Replay Import</span>
                    }
                </button>
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Database</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Database Location</div>
                <div class="setting-description">Cloud PostgreSQL Database</div>
            </div>
            <div>
                <span style="color: var(--text-muted); font-size: 13px; font-family: 'JetBrains Mono', monospace;">sc2otter-production.up.railway.app</span>
            </div>
        </div>
        <div class="setting-row" style="margin-top: 15px;">
            <div>
                <div class="setting-label" style="color: var(--accent-danger);">Wipe Database</div>
                <div class="setting-description">Danger! Permanently deletes all opponents, tags, notes, and records.</div>
            </div>
            <div>
                <button class="btn btn-danger" style="background-color: var(--accent-danger); padding: 6px 12px; color: white; border: none; border-radius: 4px;" @onclick="WipeDatabase" disabled="@IsWiping">
                    @(IsWiping ? "Wiping..." : "Wipe Everything")
                </button>
            </div>
        </div>
    </div>
    
    <div style="margin-top: 30px; display: flex; align-items: center; justify-content: flex-end; gap: 16px;">
        @if (!string.IsNullOrEmpty(WipeMessage))
        {
            <div style="color: @(WipeMessage.Contains("Failed") ? "var(--accent-danger)" : "var(--accent-success)"); font-weight: 500;">
                @WipeMessage
            </div>
        }
    </div>
</div>

@code {
    private bool IsWiping = false;
    private string SyncKey = "";
    private bool ShowSyncKey = false;
    private bool _isImporting = false;
    private int _importCurrent = 0;
    private int _importTotal = 0;
    private HubConnection? _hubConnection;
    private DateTime? LastScanTime = null;

    private string WipeMessage = "";

    protected override async Task OnInitializedAsync()
    {
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst("Sc2OtterUserId")?.Value;
        if (int.TryParse(userIdStr, out var userId))
        {
            var user = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.FirstOrDefaultAsync(DbContext.Users.AsNoTracking(), u => u.Id == userId);
            if (user != null)
            {
                SyncKey = user.SyncKey;
                LastScanTime = user.LastBulkScanAt;
                
                var url = Navigation.ToAbsoluteUri($"/scouthub?syncKey={SyncKey}").ToString();
                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(url)
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On<int, int>("BulkScanProgress", (current, total) =>
                {
                    _isImporting = true;
                    _importCurrent = current;
                    _importTotal = total;
                    if (current == total)
                    {
                        _isImporting = false;
                        LastScanTime = DateTime.UtcNow;
                    }
                    InvokeAsync(StateHasChanged);
                });

                await _hubConnection.StartAsync();
            }
        }
    }

    private async Task GenerateSyncKey()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst("Sc2OtterUserId")?.Value;
        if (int.TryParse(userIdStr, out var userId))
        {
            var user = await DbContext.Users.FindAsync(userId);
            if (user != null)
            {
                SyncKey = Guid.NewGuid().ToString("N");
                user.SyncKey = SyncKey;
                await DbContext.SaveChangesAsync();
            }
        }
    }

    private async Task TriggerBulkImport()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst("Sc2OtterUserId")?.Value;
        if (int.TryParse(userIdStr, out var userId))
        {
            _isImporting = true;
            await HubContext.Clients.Group($"User_{userId}").SendAsync("StartBulkImport");
            
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                _isImporting = false;
                await InvokeAsync(StateHasChanged);
            });
        }
    }



    private async Task WipeDatabase()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to completely wipe the database? This cannot be undone.");
        if (!confirmed) return;

        IsWiping = true;
        WipeMessage = "";
        await InvokeAsync(StateHasChanged);
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var repo = scope.ServiceProvider.GetRequiredService<IOpponentRepository>();
            await repo.WipeDatabaseAsync();
            
            Logger.LogInformation("Database wiped successfully from UI.");
            WipeMessage = "Database wiped successfully.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to wipe database");
            WipeMessage = "Failed to wipe database.";
        }
        finally
        {
            IsWiping = false;
            await InvokeAsync(StateHasChanged);
            
            _ = Task.Run(async () => 
            {
                await Task.Delay(3000);
                WipeMessage = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
