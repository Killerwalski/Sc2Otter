@page "/settings"
@rendermode InteractiveServer
@using Sc2Otter.Server.Services
@using Sc2Otter.Core.Interfaces
@inject SettingsService SettingsService
@inject IServiceScopeFactory ScopeFactory
@inject ReplayAnalysisService ReplayAnalyzer
@inject ILogger<Settings> Logger
@inject IJSRuntime JSRuntime

<div class="page-header">
    <h1>Settings</h1>
    <p>Configure Sc2Otter to your liking</p>
</div>

<div class="card">
    <div class="settings-section">
        <h3>General</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">My SC2 Username</div>
                <div class="setting-description">Your exact Starcraft II username so you aren't tracked as an opponent</div>
            </div>
            <div>
                <input type="text" class="form-control" style="width: 200px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.MySc2Name" placeholder="e.g. APECRAFT" />
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Global Hotkey</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Add Note Hotkey</div>
                <div class="setting-description">Opens the note editor for the current opponent</div>
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
                <select class="form-control" style="background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.HotkeyModifiers">
                    <option value="Ctrl">Ctrl</option>
                    <option value="Shift">Shift</option>
                    <option value="Alt">Alt</option>
                    <option value="Ctrl+Shift">Ctrl + Shift</option>
                    <option value="Ctrl+Alt">Ctrl + Alt</option>
                    <option value="Alt+Shift">Alt + Shift</option>
                    <option value="Ctrl+Alt+Shift">Ctrl + Alt + Shift</option>
                </select>
                <span>+</span>
                <select class="form-control" style="background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.HotkeyChar">
                    @for (char c = 'A'; c <= 'Z'; c++)
                    {
                        var key = c.ToString();
                        <option value="@key">@key</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>SC2 Connection</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">SC2 Client API</div>
                <div class="setting-description">Sc2Otter connects to SC2 via the official game client API</div>
            </div>
            <div>
                <span style="color: var(--text-muted); font-size: 13px; font-family: 'JetBrains Mono', monospace;">http://localhost:6119</span>
            </div>
        </div>
        <div class="setting-row">
            <div>
                <div class="setting-label">Polling Interval (ms)</div>
                <div class="setting-description">How often to check for game state changes</div>
            </div>
            <div>
                <input type="number" class="form-control" style="width: 100px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.PollingIntervalMs" min="500" max="10000" step="100" />
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Replay Analysis</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Replay Directory</div>
                <div class="setting-description">Folder containing the .SC2Replay files to scan</div>
            </div>
            <div>
                <input type="text" class="form-control" style="width: 400px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.ReplayDirectory" placeholder="C:\Path\To\Replays" />
            </div>
        </div>
        <div class="setting-row" style="margin-top: 15px;">
            <div>
                <div class="setting-label">Bulk Scan Cutoff Date</div>
                <div class="setting-description">Recommended to use the last major SC2 patch date</div>
            </div>
            <div>
                <input type="date" class="form-control" style="width: 200px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.BulkScanCutoffDate" />
            </div>
        </div>
        <div class="setting-row" style="margin-top: 15px;">
            <div>
                <div class="setting-label">Bulk Scan Replays</div>
                <div class="setting-description">Scans all replays in directory since the cutoff date</div>
            </div>
            <div>
                <button class="btn btn-secondary" style="padding: 6px 12px;" @onclick="StartBulkScan" disabled="@IsScanning">
                    @(IsScanning ? "Scanning..." : "Scan Replays")
                </button>
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Database</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Database Location</div>
                <div class="setting-description">SQLite database file path</div>
            </div>
            <div>
                <span style="color: var(--text-muted); font-size: 13px; font-family: 'JetBrains Mono', monospace;">%APPDATA%\Sc2Otter\scout.db</span>
            </div>
        </div>
        <div class="setting-row" style="margin-top: 15px;">
            <div>
                <div class="setting-label" style="color: var(--accent-danger);">Wipe Database</div>
                <div class="setting-description">Danger! Permanently deletes all opponents, tags, notes, and records.</div>
            </div>
            <div>
                <button class="btn btn-danger" style="background-color: var(--accent-danger); padding: 6px 12px; color: white; border: none; border-radius: 4px;" @onclick="WipeDatabase" disabled="@IsWiping">
                    @(IsWiping ? "Wiping..." : "Wipe Everything")
                </button>
            </div>
        </div>
    </div>
    
    <div style="margin-top: 30px; display: flex; align-items: center; justify-content: flex-end; gap: 16px;">
        @if (ShowSaved)
        {
            <div style="color: var(--accent-success); font-weight: 500;">Settings saved successfully!</div>
        }
        @if (!string.IsNullOrEmpty(WipeMessage))
        {
            <div style="color: @(WipeMessage.Contains("Failed") ? "var(--accent-danger)" : "var(--accent-success)"); font-weight: 500;">
                @WipeMessage
            </div>
        }
        <button class="btn btn-primary" style="padding: 10px 24px;" @onclick="SaveSettings">Save All Settings</button>
    </div>
</div>

@code {
    private UserSettings TempSettings { get; set; } = new();
    private bool ShowSaved = false;
    private bool IsScanning = false;
    private bool IsWiping = false;

    private string WipeMessage = "";

    protected override void OnInitialized()
    {
        TempSettings = SettingsService.Current.Clone();
    }

    private async Task SaveSettings()
    {
        SettingsService.Update(TempSettings);
        ShowSaved = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(2500);
        ShowSaved = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task WipeDatabase()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to completely wipe the database? This cannot be undone.");
        if (!confirmed) return;

        IsWiping = true;
        WipeMessage = "";
        await InvokeAsync(StateHasChanged);
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var repo = scope.ServiceProvider.GetRequiredService<IOpponentRepository>();
            await repo.WipeDatabaseAsync();
            Logger.LogInformation("Database wiped successfully from UI.");
            WipeMessage = "Database wiped successfully.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to wipe database");
            WipeMessage = "Failed to wipe database.";
        }
        finally
        {
            IsWiping = false;
            await InvokeAsync(StateHasChanged);
            
            _ = Task.Run(async () => 
            {
                await Task.Delay(3000);
                WipeMessage = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task StartBulkScan()
    {
        if (IsScanning) return;
        IsScanning = true;
        await InvokeAsync(StateHasChanged);
        
        // Ensure settings are saved first so the bulk scan uses the latest directory and MyName
        SettingsService.Update(TempSettings);
        
        _ = Task.Run(async () => 
        {
            try
            {
                var replayDir = SettingsService.Current.ReplayDirectory;
                if (!Directory.Exists(replayDir)) 
                {
                    Logger.LogWarning("Replay directory not found: {Dir}", replayDir);
                    return;
                }

                var cutoff = SettingsService.Current.BulkScanCutoffDate;
                var files = Directory.GetFiles(replayDir, "*.SC2Replay", SearchOption.AllDirectories)
                    .Where(f => f.Contains("Multiplayer") && File.GetLastWriteTimeUtc(f) >= cutoff)
                    .ToList();
                    
                Logger.LogInformation("Found {Count} replays to scan", files.Count);
                
                int count = 0;
                foreach (var file in files)
                {
                    await ReplayAnalyzer.AnalyzeReplayAsync(file);
                    count++;
                    if (count % 10 == 0) Logger.LogInformation("Scanned {Count}/{Total} replays...", count, files.Count);
                }
                Logger.LogInformation("Finished scanning all {Total} replays", files.Count);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error during bulk replay scan");
            }
            finally
            {
                IsScanning = false;
                await InvokeAsync(StateHasChanged);
            }
        });
    }
}
