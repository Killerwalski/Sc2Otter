@page "/settings"
@rendermode InteractiveServer
@using Sc2Otter.Server.Services
@inject SettingsService SettingsService

<div class="page-header">
    <h1>Settings</h1>
    <p>Configure Sc2Otter to your liking</p>
</div>

<div class="card">
    <div class="settings-section">
        <h3>General</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">My SC2 Username</div>
                <div class="setting-description">Your exact Starcraft II username so you aren't tracked as an opponent</div>
            </div>
            <div>
                <input type="text" class="form-control" style="width: 200px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.MySc2Name" placeholder="e.g. APECRAFT" />
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Global Hotkey</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Add Note Hotkey</div>
                <div class="setting-description">Opens the note editor for the current opponent</div>
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
                <select class="form-control" style="background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.HotkeyModifiers">
                    <option value="Ctrl">Ctrl</option>
                    <option value="Shift">Shift</option>
                    <option value="Alt">Alt</option>
                    <option value="Ctrl+Shift">Ctrl + Shift</option>
                    <option value="Ctrl+Alt">Ctrl + Alt</option>
                    <option value="Alt+Shift">Alt + Shift</option>
                    <option value="Ctrl+Alt+Shift">Ctrl + Alt + Shift</option>
                </select>
                <span>+</span>
                <select class="form-control" style="background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.HotkeyChar">
                    @for (char c = 'A'; c <= 'Z'; c++)
                    {
                        var key = c.ToString();
                        <option value="@key">@key</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>SC2 Connection</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">SC2 Client API</div>
                <div class="setting-description">Sc2Otter connects to SC2 via the official game client API</div>
            </div>
            <div>
                <span style="color: var(--text-muted); font-size: 13px; font-family: 'JetBrains Mono', monospace;">http://localhost:6119</span>
            </div>
        </div>
        <div class="setting-row">
            <div>
                <div class="setting-label">Polling Interval (ms)</div>
                <div class="setting-description">How often to check for game state changes</div>
            </div>
            <div>
                <input type="number" class="form-control" style="width: 100px; background: var(--bg-tertiary); color: white; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px;" @bind="TempSettings.PollingIntervalMs" min="500" max="10000" step="100" />
            </div>
        </div>
    </div>

    <div class="settings-section">
        <h3>Database</h3>
        <div class="setting-row">
            <div>
                <div class="setting-label">Database Location</div>
                <div class="setting-description">SQLite database file path</div>
            </div>
            <div>
                <span style="color: var(--text-muted); font-size: 13px; font-family: 'JetBrains Mono', monospace;">%APPDATA%\Sc2Otter\scout.db</span>
            </div>
        </div>
    </div>
    
    <div style="margin-top: 30px; display: flex; align-items: center; justify-content: flex-end; gap: 16px;">
        @if (ShowSaved)
        {
            <div style="color: var(--accent-success); font-weight: 500;">Settings saved successfully!</div>
        }
        <button class="btn btn-primary" style="padding: 10px 24px;" @onclick="SaveSettings">Save All Settings</button>
    </div>
</div>

@code {
    private UserSettings TempSettings { get; set; } = new();
    private bool ShowSaved = false;

    protected override void OnInitialized()
    {
        TempSettings = SettingsService.Current.Clone();
    }

    private async Task SaveSettings()
    {
        SettingsService.Update(TempSettings);
        ShowSaved = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(2500);
        ShowSaved = false;
        await InvokeAsync(StateHasChanged);
    }
}
