@page "/match/{Id:int}"
@rendermode InteractiveServer
@using Sc2Otter.Core.Models
@using Sc2Otter.Core.Interfaces
@using Sc2Otter.Server.Components.Shared
@using Sc2Otter.Server.Services
@inject IOpponentRepository Repo
@inject SettingsService Settings
@inject NavigationManager Navigation

@if (Match is null)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <h3>Match not found</h3>
    </div>
}
else
{
    <a href="/opponent/@Match.OpponentId" class="back-link">← Back to @Match.Opponent.Name</a>

    <div class="detail-header">
        <div>
            <div class="detail-name">Match Summary</div>
            <div class="detail-meta">
                <span>@(Match.GameMode ?? "Unknown Mode")</span>
                <span>@(Match.MapName ?? "Unknown Map")</span>
                <span>@Match.PlayedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
            </div>
        </div>
        <div class="opponent-stats" style="margin-left: auto;">
            @if (Match.Result == MatchResult.Win)
            {
                <div class="stat"><span class="stat-value wins">VICTORY</span></div>
            }
            else if (Match.Result == MatchResult.Loss)
            {
                <div class="stat"><span class="stat-value losses">DEFEAT</span></div>
            }
            else
            {
                <div class="stat"><span class="stat-value total">UNKNOWN</span></div>
            }
        </div>
    </div>

    @if (AllPlayers != null && AllPlayers.Count > 0)
    {
        var myNames = GetMyNames();
        var friendlyPlayer = AllPlayers.FirstOrDefault(p => myNames.Contains(p.Name));
        
        List<PlayerAnalysisResult> friendlyTeam = [];
        List<PlayerAnalysisResult> enemyTeam = [];
        
        if (friendlyPlayer != null)
        {
            if (friendlyPlayer.TeamId != 0)
            {
                friendlyTeam = AllPlayers.Where(p => p.TeamId == friendlyPlayer.TeamId).ToList();
                enemyTeam = AllPlayers.Where(p => p.TeamId != friendlyPlayer.TeamId).ToList();
            }
            else if (AllPlayers.Any(p => p.Result == "Win" || p.Result == "Loss"))
            {
                var friendlyResult = friendlyPlayer.Result ?? "Win";
                friendlyTeam = AllPlayers.Where(p => p.Result == friendlyResult).ToList();
                enemyTeam = AllPlayers.Where(p => p.Result != friendlyResult).ToList();
            }
            else
            {
                var half = AllPlayers.Count / 2;
                friendlyTeam = AllPlayers.Take(half).ToList();
                enemyTeam = AllPlayers.Skip(half).ToList();
            }
        }
        else
        {
            var oppPlayer = AllPlayers.FirstOrDefault(p => string.Equals(p.Name, Match.Opponent.Name, StringComparison.OrdinalIgnoreCase));
            if (oppPlayer != null)
            {
                if (oppPlayer.TeamId != 0)
                {
                    enemyTeam = AllPlayers.Where(p => p.TeamId == oppPlayer.TeamId).ToList();
                    friendlyTeam = AllPlayers.Where(p => p.TeamId != oppPlayer.TeamId).ToList();
                }
                else if (AllPlayers.Any(p => p.Result == "Win" || p.Result == "Loss"))
                {
                    var oppResult = oppPlayer.Result ?? "Loss";
                    enemyTeam = AllPlayers.Where(p => p.Result == oppResult).ToList();
                    friendlyTeam = AllPlayers.Where(p => p.Result != oppResult).ToList();
                }
                else
                {
                    // Fallback if no result or team ID is known
                    var half = AllPlayers.Count / 2;
                    enemyTeam = AllPlayers.Take(half).ToList();
                    if (enemyTeam.Contains(oppPlayer))
                    {
                        friendlyTeam = AllPlayers.Skip(half).ToList();
                    }
                    else
                    {
                        friendlyTeam = enemyTeam;
                        enemyTeam = AllPlayers.Skip(half).ToList();
                    }
                }
            }
            else
            {
                // Fallback: split in half
                var half = AllPlayers.Count / 2;
                friendlyTeam = AllPlayers.Take(half).ToList();
                enemyTeam = AllPlayers.Skip(half).ToList();
            }
        }

        <div class="card match-stats-card" style="margin-top: 24px;">
            @if (friendlyTeam.Count == 1 && enemyTeam.Count == 1)
            {
                var me = friendlyTeam[0];
                var opp = enemyTeam[0];
                var isMeStr = myNames.Contains(me.Name) ? $"You ({me.Name})" : me.Name;

                <div class="stats-comparison">
                    <div class="stats-column you">
                        <h3>@isMeStr</h3>
                        <div class="stats-race">@me.Race</div>
                    </div>
                    
                    <div class="stats-column middle">
                        <h3>VS</h3>
                    </div>

                    <div class="stats-column opponent">
                        @if (_playerOpponentIds.TryGetValue(opp.Name, out var oppId))
                        {
                            <h3><a href="/opponent/@oppId" style="color: inherit;">@opp.Name</a></h3>
                        }
                        else
                        {
                            <h3>@opp.Name</h3>
                        }
                        <div class="stats-race">@opp.Race</div>
                    </div>
                </div>

                <div class="stats-metrics">
                    <StatRow Label="Workers Created" 
                             MyValue="@(me.Stats?.WorkersCreated)" 
                             OpponentValue="@(opp.Stats?.WorkersCreated)" 
                             LowerIsBetter="false" />
                             
                    <StatRow Label="Avg Unspent Minerals" 
                             MyValue="@(me.Stats?.AvgUnspentMinerals)" 
                             OpponentValue="@(opp.Stats?.AvgUnspentMinerals)" 
                             LowerIsBetter="true" />
                             
                    <StatRow Label="Avg Mineral Income" 
                             MyValue="@(me.Stats?.AvgMineralIncome)" 
                             OpponentValue="@(opp.Stats?.AvgMineralIncome)" 
                             LowerIsBetter="false" />
                             
                    <StatRow Label="Time Supply Blocked" 
                             MyValue="@(me.Stats?.SupplyBlockTime)" 
                             OpponentValue="@(opp.Stats?.SupplyBlockTime)" 
                             Format="s"
                             LowerIsBetter="true" />
                </div>

                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                    <h3 style="text-align: center; color: var(--text-muted); margin-bottom: 24px;">Units Made</h3>
                    <div class="units-comparison" style="display: flex; gap: 40px;">
                        <div class="units-column you" style="flex: 1;">
                            @if (me.UnitsMade != null && me.UnitsMade.Any())
                            {
                                <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                    <tbody>
                                        @foreach (var unit in me.UnitsMade.OrderByDescending(k => k.Value))
                                        {
                                            <tr>
                                                <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                                <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-primary);">@unit.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                        
                        <div class="units-column opponent" style="flex: 1;">
                            @if (opp.UnitsMade != null && opp.UnitsMade.Any())
                            {
                                <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                    <tbody>
                                        @foreach (var unit in opp.UnitsMade.OrderByDescending(k => k.Value))
                                        {
                                            <tr>
                                                <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                                <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-secondary);">@unit.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div style="padding-top: 24px;">
                    <h3 style="text-align: center; color: var(--text-muted); margin-bottom: 24px;">Player Stats</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 32px;">
                        
                        <!-- Friendly Team Stats -->
                        <div>
                            <h3 style="color: var(--accent-primary); margin-bottom: 16px;">Your Team</h3>
                            <div style="display: flex; flex-wrap: wrap; gap: 40px;">
                                @foreach (var player in friendlyTeam)
                                {
                                    var isMe = myNames.Contains(player.Name);
                                    <div class="units-column you" style="flex: 1; min-width: 200px;">
                                        <h4 style="margin-bottom: 12px; color: var(--text-primary);">
                                            @if (!isMe && _playerOpponentIds.TryGetValue(player.Name, out var fId))
                                            {
                                                <a href="/opponent/@fId" style="color: inherit;">@player.Name</a>
                                            }
                                            else
                                            {
                                                @(isMe ? $"You ({player.Name})" : player.Name)
                                            }
                                            <span style="color: var(--text-muted); font-size: 12px; margin-left: 8px;">@player.Race</span>
                                        </h4>
                                        
                                        @if (player.Stats != null)
                                        {
                                            <div style="font-size: 13px;">
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Workers Created</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.WorkersCreated</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Avg Unspent</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.AvgUnspentMinerals</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Avg Income</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.AvgMineralIncome</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Supply Blocked</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@(player.Stats.SupplyBlockTime)s</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Divider -->
                        <div style="text-align: center; font-weight: bold; color: var(--text-muted); font-size: 14px; margin: 16px 0; border-bottom: 1px solid var(--border-color); line-height: 0.1em;">
                            <span style="background-color: var(--surface-1); padding: 0 16px;">VS</span>
                        </div>

                        <!-- Enemy Team Stats -->
                        <div>
                            <h3 style="color: var(--accent-secondary); margin-bottom: 16px;">Opponent Team</h3>
                            <div style="display: flex; flex-wrap: wrap; gap: 40px;">
                                @foreach (var player in enemyTeam)
                                {
                                    <div class="units-column opponent" style="flex: 1; min-width: 200px;">
                                        <h4 style="margin-bottom: 12px; color: var(--text-primary);">
                                            @if (_playerOpponentIds.TryGetValue(player.Name, out var eId))
                                            {
                                                <a href="/opponent/@eId" style="color: inherit;">@player.Name</a>
                                            }
                                            else
                                            {
                                                @player.Name
                                            }
                                            <span style="color: var(--text-muted); font-size: 12px; margin-left: 8px;">@player.Race</span>
                                        </h4>

                                        @if (player.Stats != null)
                                        {
                                            <div style="font-size: 13px;">
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Workers Created</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.WorkersCreated</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Avg Unspent</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.AvgUnspentMinerals</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Avg Income</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@player.Stats.AvgMineralIncome</span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                                                    <span style="color: var(--text-muted);">Supply Blocked</span>
                                                    <span style="font-weight: 500; color: var(--text-primary);">@(player.Stats.SupplyBlockTime)s</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
                
                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                    <h3 style="text-align: center; color: var(--text-muted); margin-bottom: 24px;">Units Made</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 32px;">
                        <!-- Friendly Team Units -->
                        <div>
                            <h3 style="color: var(--accent-primary); margin-bottom: 16px;">Your Team</h3>
                            <div style="display: flex; flex-wrap: wrap; gap: 40px;">
                                @foreach (var player in friendlyTeam)
                                {
                                    var isMe = myNames.Contains(player.Name);
                                    <div class="units-column you" style="flex: 1; min-width: 200px;">
                                        <h4 style="margin-bottom: 12px; color: var(--text-primary);">
                                            @if (!isMe && _playerOpponentIds.TryGetValue(player.Name, out var fId2))
                                            {
                                                <a href="/opponent/@fId2" style="color: inherit;">@player.Name</a>
                                            }
                                            else
                                            {
                                                @(isMe ? $"You ({player.Name})" : player.Name)
                                            }
                                        </h4>
                                        @if (player.UnitsMade != null && player.UnitsMade.Any())
                                        {
                                            <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                                <tbody>
                                                    @foreach (var unit in player.UnitsMade.OrderByDescending(k => k.Value))
                                                    {
                                                        <tr>
                                                            <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                                            <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-primary);">@unit.Value</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Divider -->
                        <div style="text-align: center; font-weight: bold; color: var(--text-muted); font-size: 14px; margin: 16px 0; border-bottom: 1px solid var(--border-color); line-height: 0.1em;">
                            <span style="background-color: var(--surface-1); padding: 0 16px;">VS</span>
                        </div>

                        <!-- Enemy Team Units -->
                        <div>
                            <h3 style="color: var(--accent-secondary); margin-bottom: 16px;">Opponent Team</h3>
                            <div style="display: flex; flex-wrap: wrap; gap: 40px;">
                                @foreach (var player in enemyTeam)
                                {
                                    <div class="units-column opponent" style="flex: 1; min-width: 200px;">
                                        <h4 style="margin-bottom: 12px; color: var(--text-primary);">
                                            @if (_playerOpponentIds.TryGetValue(player.Name, out var eId2))
                                            {
                                                <a href="/opponent/@eId2" style="color: inherit;">@player.Name</a>
                                            }
                                            else
                                            {
                                                @player.Name
                                            }
                                        </h4>
                                        @if (player.UnitsMade != null && player.UnitsMade.Any())
                                        {
                                            <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                                <tbody>
                                                    @foreach (var unit in player.UnitsMade.OrderByDescending(k => k.Value))
                                                    {
                                                        <tr>
                                                            <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                                            <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-secondary);">@unit.Value</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Fallback to Legacy 1v1 View if no FullMatchData -->
        <div class="card match-stats-card" style="margin-top: 24px;">
            <div class="stats-comparison">
                <div class="stats-column you">
                    <h3>You</h3>
                    <div class="stats-race">@(Match.MyRace ?? "Unknown")</div>
                </div>
                
                <div class="stats-column middle">
                    <h3>VS</h3>
                </div>

                <div class="stats-column opponent">
                    <h3><a href="/opponent/@Match.OpponentId" style="color: inherit;">@Match.Opponent.Name</a></h3>
                    <div class="stats-race">@(Match.OpponentRace ?? "Unknown")</div>
                </div>
            </div>

            <div class="stats-metrics">
                <StatRow Label="Workers Created" 
                         MyValue="@Match.MyWorkersCreated" 
                         OpponentValue="@Match.OpponentWorkersCreated" 
                         LowerIsBetter="false" />
                         
                <StatRow Label="Avg Unspent Minerals" 
                         MyValue="@Match.MyAvgUnspentMinerals" 
                         OpponentValue="@Match.OpponentAvgUnspentMinerals" 
                         LowerIsBetter="true" />
                         
                <StatRow Label="Avg Mineral Income" 
                         MyValue="@Match.MyAvgMineralIncome" 
                         OpponentValue="@Match.OpponentAvgMineralIncome" 
                         LowerIsBetter="false" />
                         
                <StatRow Label="Time Supply Blocked" 
                         MyValue="@Match.MySupplyBlockTime" 
                         OpponentValue="@Match.OpponentSupplyBlockTime" 
                         Format="s"
                         LowerIsBetter="true" />
            </div>

            <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                <h3 style="text-align: center; color: var(--text-muted); margin-bottom: 24px;">Units Made</h3>
                <div class="units-comparison" style="display: flex; gap: 40px;">
                    <div class="units-column you" style="flex: 1;">
                        @if (MyUnits != null && MyUnits.Any())
                        {
                            <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                <tbody>
                                    @foreach (var unit in MyUnits.OrderByDescending(k => k.Value))
                                    {
                                        <tr>
                                            <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                            <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-primary);">@unit.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                    
                    <div class="units-column opponent" style="flex: 1;">
                        @if (OpponentUnits != null && OpponentUnits.Any())
                        {
                            <table class="units-table" style="width: 100%; text-align: left; font-size: 14px;">
                                <tbody>
                                    @foreach (var unit in OpponentUnits.OrderByDescending(k => k.Value))
                                    {
                                        <tr>
                                            <td style="padding: 4px 0; color: var(--text-muted);">@unit.Key</td>
                                            <td style="padding: 4px 0; text-align: right; font-weight: 500; color: var(--accent-secondary);">@unit.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private MatchRecord? Match { get; set; }
    private Dictionary<string, int>? MyUnits;
    private Dictionary<string, int>? OpponentUnits;
    private List<PlayerAnalysisResult>? AllPlayers;
    private Dictionary<string, int> _playerOpponentIds = new();

    private class PlayerAnalysisResult
    {
        public string Name { get; set; } = "";
        public string Race { get; set; } = "";
        public string? Result { get; set; }
        public int TeamId { get; set; }
        public Dictionary<string, int>? UnitsMade { get; set; }
        public PlayerStatsResult? Stats { get; set; }
    }

    private class PlayerStatsResult
    {
        public int WorkersCreated { get; set; }
        public int SupplyBlockTime { get; set; }
        public int AvgUnspentMinerals { get; set; }
        public int AvgMineralIncome { get; set; }
    }

    private HashSet<string> GetMyNames()
    {
        var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(Settings.Current.MySc2Name))
        {
            foreach (var n in Settings.Current.MySc2Name.Split(',', StringSplitOptions.RemoveEmptyEntries))
                set.Add(n.Trim());
        }
        return set;
    }

    protected override async Task OnParametersSetAsync()
    {
        Match = await Repo.GetMatchByIdAsync(Id);
        if (Match != null)
        {
            if (!string.IsNullOrEmpty(Match.FullMatchData))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                AllPlayers = System.Text.Json.JsonSerializer.Deserialize<List<PlayerAnalysisResult>>(Match.FullMatchData, options);
            }
            
            if (!string.IsNullOrEmpty(Match.MyUnitsMade))
            {
                MyUnits = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(Match.MyUnitsMade);
            }
            if (!string.IsNullOrEmpty(Match.OpponentUnitsMade))
            {
                OpponentUnits = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(Match.OpponentUnitsMade);
            }
            
            if (AllPlayers != null)
            {
                foreach (var player in AllPlayers)
                {
                    var opp = await Repo.FindByNameAsync(player.Name);
                    if (opp != null)
                    {
                        _playerOpponentIds[player.Name] = opp.Id;
                    }
                }
            }
        }
    }
}
