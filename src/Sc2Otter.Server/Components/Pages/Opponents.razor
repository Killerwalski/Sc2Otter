@page "/opponents"
@rendermode InteractiveServer
@using Sc2Otter.Core.Models
@using Sc2Otter.Core.Interfaces
@inject IOpponentRepository Repo
@inject NavigationManager Navigation

<div class="page-header">
    <h1>Opponents (@OpponentList.Count)</h1>
    <p>Browse and search your scouting database</p>
</div>

<div class="search-container">
    <span class="search-icon">🔍</span>
    <input class="input" type="text" placeholder="Search by name..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="Search" />
</div>

<div class="filter-bar">
    <button class="filter-chip @(RaceFilter == null ? "active" : "")" @onclick="() => SetRaceFilter(null)">All</button>
    <button class="filter-chip @(RaceFilter == "Terran" ? "active" : "")" @onclick="@(() => SetRaceFilter("Terran"))">Terran</button>
    <button class="filter-chip @(RaceFilter == "Protoss" ? "active" : "")" @onclick="@(() => SetRaceFilter("Protoss"))">Protoss</button>
    <button class="filter-chip @(RaceFilter == "Zerg" ? "active" : "")" @onclick="@(() => SetRaceFilter("Zerg"))">Zerg</button>
    <button class="filter-chip @(RaceFilter == "Random" ? "active" : "")" @onclick="@(() => SetRaceFilter("Random"))">Random</button>
    <div style="width: 8px;"></div>
    <div style="border-left: 1px solid var(--border-color); height: 24px; margin: 0 8px;"></div>
    <div style="width: 8px;"></div>
    <button class="filter-chip @(ModeFilter == "1v1" ? "active" : "")" @onclick="@(() => ToggleModeFilter("1v1"))">1v1</button>
    <button class="filter-chip @(ModeFilter == "2v2" ? "active" : "")" @onclick="@(() => ToggleModeFilter("2v2"))">2v2</button>
    <button class="filter-chip @(ModeFilter == "3v3" ? "active" : "")" @onclick="@(() => ToggleModeFilter("3v3"))">3v3</button>
    <button class="filter-chip @(ModeFilter == "4v4" ? "active" : "")" @onclick="@(() => ToggleModeFilter("4v4"))">4v4</button>
    <div style="flex-grow: 1"></div>
    <select class="input" style="width: auto; padding: 4px 12px; height: 32px; border-radius: 16px; background-color: var(--surface-2); border: 1px solid var(--border);" @bind="SortBy" @bind:after="ApplySort">
        <option value="LastSeen">Sort by: Last Seen</option>
        <option value="Games">Sort by: Games Played</option>
        <option value="Wins">Sort by: Wins</option>
        <option value="Losses">Sort by: Losses</option>
    </select>
</div>

@if (OpponentList.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">👥</div>
        <h3>No opponents found</h3>
        <p>@(string.IsNullOrEmpty(SearchQuery) ? "Play some games and your opponents will appear here" : "Try a different search term")</p>
    </div>
}
else
{
    <div class="opponents-grid">
        @foreach (var opp in OpponentList)
        {
            var wins = opp.MatchRecords?.Count(m => m.Result == MatchResult.Win) ?? 0;
            var losses = opp.MatchRecords?.Count(m => m.Result == MatchResult.Loss) ?? 0;
            var total = opp.MatchRecords?.Count ?? 0;

            <div class="opponent-card race-@(opp.Race?.ToLower() ?? "random")" @onclick="() => NavigateToOpponent(opp.Id)">
                <div class="opponent-card-header">
                    <span class="opponent-name">@opp.Name</span>
                    <span class="opponent-race">@(opp.Race ?? "Unknown")</span>
                </div>
                <div class="opponent-stats">
                    <div class="stat"><span class="stat-value total">@total</span><span class="stat-label">Games</span></div>
                    <div class="stat"><span class="stat-value wins">@wins</span><span class="stat-label">Wins</span></div>
                    <div class="stat"><span class="stat-value losses">@losses</span><span class="stat-label">Losses</span></div>
                </div>
                @if (opp.TagAssignments.Count > 0)
                {
                    <div class="tags-container">
                        @foreach (var ta in opp.TagAssignments)
                        {
                            <span class="tag">@ta.Tag.Name@(ta.Count > 1 ? $" x{ta.Count}" : "")</span>
                        }
                    </div>
                }
                <div class="note-meta" style="margin-top: 8px">
                    <span>Last seen: @opp.LastSeen.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private string? SearchQuery { get; set; }
    private string? RaceFilter { get; set; }
    private string? ModeFilter { get; set; }
    private string SortBy { get; set; } = "LastSeen";
    private List<Opponent> OpponentList { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadOpponents();
    }

    private async Task Search()
    {
        await LoadOpponents();
    }

    private async Task SetRaceFilter(string? race)
    {
        RaceFilter = race;
        await LoadOpponents();
    }

    private async Task ToggleModeFilter(string mode)
    {
        if (ModeFilter == mode) ModeFilter = null;
        else ModeFilter = mode;
        await LoadOpponents();
    }

    private async Task LoadOpponents()
    {
        OpponentList = await Repo.SearchAsync(SearchQuery, RaceFilter, null, ModeFilter);
        ApplySort();
    }

    private void ApplySort()
    {
        OpponentList = SortBy switch
        {
            "Games" => OpponentList.OrderByDescending(o => o.MatchRecords?.Count ?? 0).ToList(),
            "Wins" => OpponentList.OrderByDescending(o => o.MatchRecords?.Count(m => m.Result == MatchResult.Win) ?? 0).ToList(),
            "Losses" => OpponentList.OrderByDescending(o => o.MatchRecords?.Count(m => m.Result == MatchResult.Loss) ?? 0).ToList(),
            _ => OpponentList.OrderByDescending(o => o.LastSeen).ToList()
        };
    }

    private void NavigateToOpponent(int id) => Navigation.NavigateTo($"/opponent/{id}");
}
