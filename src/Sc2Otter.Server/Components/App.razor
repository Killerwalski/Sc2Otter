<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sc2Otter — SC2 Opponent Scout</title>
    <meta name="description" content="Track and scout your StarCraft 2 opponents" />
    <base href="/" />
    <link rel="stylesheet" href="/css/app.css" />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script>
        window.formatLocalTime = (element, utcString, includeYear) => {
            const date = new Date(utcString);
            const options = { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' };
            if (includeYear) options.year = 'numeric';
            element.innerText = date.toLocaleString([], options);
        };
    </script>
    <script src="/_framework/blazor.web.js"></script>
    <script src="/js/notifications.js"></script>
</body>
</html>
